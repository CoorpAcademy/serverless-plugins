# The published offline plugins keep an intentionally wide `serverless-offline: >=11` peer range, and
# serverless-offline@14 peers `serverless@^4` — which conflicts with our osls (Serverless v3) CLI.
# legacy-peer-deps lets the install proceed instead of erroring on that peer mismatch; the root
# `overrides` in package.json is what actually pins serverless-offline to 13.x everywhere (so the
# dev/test harness deterministically runs serverless-offline 13 on osls 3, not serverless-offline 14).
legacy-peer-deps=true
